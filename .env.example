# ─────────────────────────────────────────
#  MCP Server — Variables de entorno
# ─────────────────────────────────────────

# Servidor
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_SERVER_NAME=mcp-banorte

# Base de datos
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/mcp_db
# Para desarrollo local con SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./data/mcp.db

# Directorio de trabajo para archivos
FILES_BASE_DIR=/app/data
OUTPUT_DIR=/app/output

# APIs externas (ejemplo Banorte)
BANORTE_API_BASE_URL=https://api.banorte.com
BANORTE_API_KEY=your_api_key_here
BANORTE_API_SECRET=your_api_secret_here
BANORTE_TIMEOUT=30

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
